{
  "name": "corum-monorepo",
  "version": "0.1.0-alpha",
  "private": true,
  "workspaces": [
    "desktop",
    "web",
    "shared"
  ],
  "scripts": {
    "dev:desktop": "npm run dev --workspace=desktop",
    "dev:web": "npm run dev --workspace=web",
    "desktop:dev:exe": "npm run tauri dev --workspace=desktop",
    "desktop:build:exe": "npm run tauri build --workspace=desktop"
  },
  "devDependencies": {
    "vercel": "^54.16.0"
  }
}
